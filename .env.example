# mails-gtm-agent environment variables

# Required: OpenRouter API key for LLM (email generation, reply classification)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Required: mails-agent API for sending/receiving email
# Option A: Hosted mode (mails0.com)
MAILS_API_KEY=your-mails-api-key
# Option B: Self-hosted Worker
# MAILS_WORKER_URL=https://your-mails-worker.workers.dev
# MAILS_WORKER_TOKEN=your-worker-token

# Required: Admin token for the GTM agent API
ADMIN_TOKEN=your-admin-token

# Optional: Webhook URL for notifications (Slack, Discord, etc.)
# WEBHOOK_URL=https://hooks.slack.com/services/xxx

# Cloudflare (set via `wrangler secret put`)
# D1_DATABASE_ID is in wrangler.toml
# Queues are created via: wrangler queues create mails-gtm-send && wrangler queues create mails-gtm-evaluate
