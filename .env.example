# mails-gtm-agent environment variables

# ─── LLM provider ────────────────────────────────────────────────────
# The agent talks to any OpenAI-API-compatible gateway. Defaults to
# EasyRouter (https://easyrouter.io). Set ONE of the following:
#
#   (recommended) provider-agnostic
LLM_API_KEY=your-llm-api-key
# LLM_BASE_URL=https://easyrouter.io/v1/chat/completions   # default
# LLM_MODEL=anthropic/claude-sonnet-4                       # default
#
#   (convenience) explicit EasyRouter
# EASYROUTER_API_KEY=your-easyrouter-key
#
#   (deprecated) old OpenRouter deployments
# OPENROUTER_API_KEY=sk-or-v1-xxx

# ─── mails-agent (email delivery) ────────────────────────────────────
# Hosted mode (mails0.com) or self-hosted Worker exposing /v1 routes
MAILS_API_URL=https://api.mails0.com
MAILS_API_KEY=your-mails-api-key
MAILS_MAILBOX=agent@mails0.com

# ─── Auth + secrets ──────────────────────────────────────────────────
# Required: Admin token for the GTM agent API
ADMIN_TOKEN=your-admin-token

# Required for unsubscribe tokens. Must be different from ADMIN_TOKEN in production.
UNSUBSCRIBE_SECRET=your-random-unsubscribe-secret

# Optional: verify inbound webhooks from mails-agent with the same WEBHOOK_SECRET
# configured on the mails Worker.
# WEBHOOK_SECRET=your-webhook-secret

# Optional: Webhook URL for owner notifications (Slack, Discord, custom HTTP)
# WEBHOOK_URL=https://hooks.slack.com/services/xxx

# ─── Cloudflare (set via `wrangler secret put`) ──────────────────────
# D1_DATABASE_ID is in wrangler.toml
# Queues are created via: wrangler queues create mails-gtm-send \
#                       && wrangler queues create mails-gtm-evaluate \
#                       && wrangler queues create mails-gtm-dlq-send \
#                       && wrangler queues create mails-gtm-dlq-evaluate
